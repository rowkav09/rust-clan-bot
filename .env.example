# Discord
BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# Role IDs (set after /setup runs, but can pre-fill)
LEADER_ROLE_ID=
OFFICER_ROLE_ID=
MEMBER_ROLE_ID=
RECRUIT_ROLE_ID=

# Channel IDs
LOG_CHANNEL_ID=
APPLICATION_CHANNEL_ID=
RAID_CHANNEL_ID=
WIPE_CHANNEL_ID=

# Optional: role applied automatically while a member is in-game
INGAME_ROLE_ID=

# Optional: channel where members paste their Steam profile to auto-link tracking
LINK_CHANNEL_ID=

# Optional: text channel hosting the live population embed (pop + graph + alerts)
POP_CHANNEL_ID=

# Optional: Steam Web API key — enables auto Rust-hour verification on /apply
# Get one free at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# BattleMetrics (optional — for live server status & auto time tracking)
# Get your server ID from: https://www.battlemetrics.com
BATTLEMETRICS_SERVER_ID=
BATTLEMETRICS_API_TOKEN=

# Wipe day (0=Sun 1=Mon ... 4=Thu 5=Fri 6=Sat) and hour (UTC)
WIPE_DAY=4
WIPE_HOUR=19

# ── Web dashboard (dashboard/ — see README "Web dashboard") ─────────────────
# Small HTTP API served by the bot process; the dashboard talks to it.
# Set DASHBOARD_API_PORT=0 to disable entirely.
DASHBOARD_API_PORT=3055

# Public URL of the deployed dashboard (used for CORS + OAuth redirects).
DASHBOARD_URL=http://localhost:3000

# Secret used to sign dashboard session tokens (JWT). Any long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_JWT_SECRET=

# Discord OAuth2 for dashboard login ("Login with Discord").
# Create/reuse the application at https://discord.com/developers/applications,
# then add DISCORD_REDIRECT_URI under OAuth2 → Redirects.
# Without these the dashboard falls back to a clearly-labelled dev/mock login.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3055/auth/callback
